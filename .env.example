# Sentinel SOC Tier 1 Lab — environment variables
#
# Copy to .env (which is git-ignored) and fill in your own values.
# Everything in this file is optional — the lab boots fully without any of it,
# you just won't get voice playback for Morgan's lines.

# ----- ElevenLabs (optional) -----
# Used by the in-app Test Voice button and Morgan's spoken dialogue.
# Easiest path: leave these blank here and paste them into the in-app
# Settings page instead. Both flows write to the same SQLite settings row.
#
# Get a key:    https://elevenlabs.io/app/settings/api-keys
# Get a voice:  https://elevenlabs.io/app/voice-lab  (use the ID, not the name)

ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=

# ----- Server -----
# Port the Express server binds to. Defaults to 5000 if unset.
PORT=5000
